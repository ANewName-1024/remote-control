# Remote-Control Windows Agent config
# Copy to %APPDATA%\RemoteControlAgent\agent.env (preferred) or alongside agent.py

# WebSocket URL of the VPS relay (use wss:// for production; ws:// for local dev)
WS_URL=wss://8.137.116.121:8443

# Shared secret (must match server ACCESS_PASSWORD)
ACCESS_PASSWORD=change-me-to-match-server

# Stable per-machine identifier (any string; appears in client_id and admin UI)
AGENT_ID=windows-hostname-here

# Logging
LOG_LEVEL=INFO

# Optional: directory to write screenshots / recordings (default: %APPDATA%\RemoteControlAgent)
DATA_DIR=
