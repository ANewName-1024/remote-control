# Remote-Control VPS Server config
# Copy to server/.env on the VPS deployment directory and fill in real values.

# Node.js relay listen port (must match the nginx upstream on VPS)
PORT=21112

# Web client shared secret (long random string; client uses sha256 hex in auth)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ACCESS_PASSWORD=change-me-to-a-32-byte-hex-string

# Bind address (default 0.0.0.0; nginx reverse-proxies from 9080/8443)
HOST=0.0.0.0

# Optional: trust proxy headers from nginx
TRUST_PROXY=1
