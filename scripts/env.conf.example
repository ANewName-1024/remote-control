# Spring Cloud Demo 环境配置
# 复制此文件到 /opt/springcloud-demo/config/env.conf

# ===================
# Eureka 配置
# ===================
EUREKA_HOST=localhost
EUREKA_PORT=8761
EUREKA_USER=admin
EUREKA_PASSWORD=Eureka@2024

# ===================
# 数据库配置
# ===================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=springcloud
DB_USER=business
DB_PASSWORD=Business@123

# ===================
# JWT 配置
# ===================
JWT_SECRET=your-256-bit-secret-key-here-change-in-production

# ===================
# 服务端口
# ===================
EUREKA_PORT=8761
CONFIG_PORT=8082
USER_PORT=8081
GATEWAY_PORT=8080
OPS_PORT=8090

# ===================
# 可选功能
# ===================
ENABLE_OPS=true
